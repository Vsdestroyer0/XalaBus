{
  "version": 8,
  "name": "XalaBus-GoogleStyle",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "mbtiles://{mbtiles_path}/xalapa.mbtiles"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f1f3f4" }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": { "fill-color": "#f8f9fa" }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#d2f3d6" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#aadaff" }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "paint": {
        "fill-color": "#e8eaed",
        "fill-outline-color": "#dadce0"
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "minor", "service", "track"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#e0e0e0",
        "line-width": { "stops": [[14, 1.5], [15, 3], [18, 10]] }
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "minor", "service", "track"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": { "stops": [[14, 1], [15, 2], [18, 8]] }
      }
    },
    {
      "id": "road-main-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "primary", "secondary", "tertiary", "trunk"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#f9a825",
        "line-width": { "stops": [[10, 1], [12, 2.5], [14, 6], [18, 14]] }
      }
    },
    {
      "id": "road-main",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "primary", "secondary", "tertiary", "trunk"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#fff176",
        "line-width": { "stops": [[10, 0.5], [12, 1.5], [14, 4], [18, 12]] }
      }
    },
    }
  ]
}
